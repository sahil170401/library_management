    "insert_after": "has_serial_no",
    "label": "Library Management",
    "module": "Library Management",
    "name": "Item-library_section"
  },
  {
    "default": "1",
    "doctype": "Custom Field",
    "dt": "Item",
    "fieldname": "library_is_catalog_item",
    "fieldtype": "Check",
    "insert_after": "library_section",
    "label": "Library Catalog Item",
    "module": "Library Management",
    "name": "Item-library_is_catalog_item"
  },
  {
    "doctype": "Custom Field",
    "dt": "Item",
    "fieldname": "library_material_type",
